{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/assets/*", "/*.css", "/*.js", "/*.wasm", "/*.svg", "/*.png", "/*.jpg", "/*.ico"]
  },
  "globalHeaders": {
    "Permissions-Policy": "camera=(self), microphone=(self), geolocation=(self)",
    "X-Content-Type-Options": "nosniff",
    "Referrer-Policy": "strict-origin-when-cross-origin"
  },
  "routes": [
    {
      "route": "/signup",
      "headers": {
        "Permissions-Policy": "camera=(self), microphone=(self), geolocation=(self)"
      }
    },
    {
      "route": "/signup/*",
      "headers": {
        "Permissions-Policy": "camera=(self), microphone=(self), geolocation=(self)"
      }
    }
  ]
}
